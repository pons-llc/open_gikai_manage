{
  "name": "open-gikai",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "db:migrate:local": "wrangler d1 migrations apply open-gikai --local",
    "db:migrate:remote": "wrangler d1 migrations apply open-gikai --remote",
    "test": "vitest run",
    "test:watch": "vitest",
    "create-admin": "tsx scripts/create-admin.ts",
    "seed-demo": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.62.0"
  }
}
